# Gitleaks Ignore Rules for Travel Agents
# https://gitleaks.github.io

# Ignore config files with template patterns
ignorepath = ".gitleaks.*"
ignorepath = ".gitignore"
ignorepath = "CLAUDE.md"
ignorepath = "ARCHITECTURE.md"
ignorepath = "IMPLEMENTATION_SUMMARY.md"
ignorepath = "PROJECT.md"
ignorepath = "QUICK*.md"
ignorepath = "SETUP*.md"
ignorepath = "VERSION.md"
ignorepath = "LICENSE"

# Ignore common file patterns
ignoreregex = '\.md$'
ignoreregex = '\.example\..*$'
ignoreregex = '\.sample\..*$'

# Ignore vendor directories  
ignoreglob = "**/node_modules/**"
ignoreglob = "**/vendor/**"
ignoreglob = "**/test/**"
ignoreglob = "**/tests/**"
ignoreglob = ".git/**"
