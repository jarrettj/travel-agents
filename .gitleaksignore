# Gitleaks Ignore Rules for Travel Agents
# https://github.com/gitleaks/gitleaks

# Allowlist for common patterns that aren't secrets

# Allow specific commits that intentionally contain patterns
ignore_keyword = "TODO"

# Ignore common API key patterns that appear in documentation
ignore_keyword = "example"
ignore_keyword = "demo"
ignore_keyword = "placeholder"

# Ignore config files with comment patterns
ignore_path_regex = '.*\\.md$'
ignore_path_regex = '.*\\.example\\..*$'
ignore_path_regex = '.*\\.sample\\..*$'

# Ignore old commits from initial setup
ignore_globs = ['**/node_modules/**']
ignore_globs = ['**/vendor/**']
ignore_globs = ['**/test/**']
ignore_globs = ['**/tests/**']
ignore_globs = ['.git/**']
